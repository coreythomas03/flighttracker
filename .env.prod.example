# Production / cloud VM environment. Copy to .env.prod and set strong values.
# On VM: docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.cloud.yml up -d --build
# Use a strong DB_PASSWORD and limit DB_USER privileges in MySQL.

DB_HOST=mysql
DB_PORT=3306
DB_NAME=nba_flight_tracker
DB_USER=flight_user
DB_PASSWORD=use_strong_random_password_here
