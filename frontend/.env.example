# Backend API base (axios uses /teams, /flights, … under this path).
# VM default per docs/DEVELOPER_ACCESS.md — copy to .env and change IP if the team rotates it.
# Local Docker: http://localhost:8080/api
REACT_APP_API_BASE_URL=http://34.134.223.201:8080/api

# Polling intervals (milliseconds)
REACT_APP_FLIGHT_POLL_INTERVAL=60000
REACT_APP_POSITION_POLL_INTERVAL=10000

# Map configuration (if using maps)
REACT_APP_MAP_API_KEY=your_map_api_key_here
